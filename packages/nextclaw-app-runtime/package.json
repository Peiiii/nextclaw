{
  "name": "@nextclaw/app-runtime",
  "version": "0.2.0",
  "private": false,
  "description": "Standalone micro app runtime and CLI for NextClaw apps.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Peiiii/nextclaw.git"
  },
  "homepage": "https://github.com/Peiiii/nextclaw/tree/master/packages/nextclaw-app-runtime",
  "bugs": {
    "url": "https://github.com/Peiiii/nextclaw/issues"
  },
  "keywords": [
    "nextclaw",
    "micro-app",
    "wasm",
    "webview",
    "app-runtime",
    "cli"
  ],
  "bin": {
    "napp": "dist/main.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/main.ts --dts --clean --target es2022 --no-fixedExtension --unbundle",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "tsc": "tsc -p tsconfig.json",
    "test": "vitest run",
    "smoke": "node scripts/smoke.mjs",
    "prepublishOnly": "node ../../scripts/release/ensure-pnpm-publish.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.17.6",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  }
}
