{
  "contractKind": "protocol",
  "protocol": "source-root-open",
  "rootPolicy": "contract-only",
  "enforcement": "error",
  "allowedRootDirectories": [
    "bridge",
    "bundle",
    "cli",
    "commands",
    "host",
    "install",
    "manifest",
    "paths",
    "permissions",
    "publish",
    "registry",
    "runtime",
    "scaffold",
    "sidecar",
    "ui"
  ],
  "allowedRootFiles": [
    "index.ts",
    "main.ts"
  ]
}
