{
  "name": "@nextclaw/server",
  "version": "0.12.26",
  "private": false,
  "description": "Nextclaw UI/API server.",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts.sourcemap --clean --target es2022 --no-fixedExtension",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "tsc": "tsc -p tsconfig.json",
    "test": "vitest",
    "prepublishOnly": "node ../../scripts/release/ensure-pnpm-publish.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.3",
    "@nextclaw/core": "workspace:*",
    "@nextclaw/kernel": "workspace:*",
    "@nextclaw/mcp": "workspace:*",
    "@nextclaw/ncp": "workspace:*",
    "@nextclaw/runtime": "workspace:*",
    "hono": "^4.6.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/ws": "^8.5.14",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  }
}
