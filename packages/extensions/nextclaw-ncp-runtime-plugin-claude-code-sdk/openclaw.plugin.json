{
  "id": "nextclaw-ncp-runtime-plugin-claude-code-sdk",
  "kind": "agent-runtime",
  "name": "NextClaw Claude NCP Runtime",
  "description": "Registers NCP session type `claude` backed by Anthropic Claude Agent SDK.",
  "version": "0.1.2",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "apiKey": {
        "type": "string"
      },
      "authToken": {
        "type": "string"
      },
      "apiBase": {
        "type": "string"
      },
      "model": {
        "type": "string"
      },
      "useProviderCredentials": {
        "type": "boolean"
      },
      "anthropicCompatibleProviderNames": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "gatewayProviderNames": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "workingDirectory": {
        "type": "string"
      },
      "permissionMode": {
        "type": "string",
        "enum": ["default", "acceptEdits", "bypassPermissions", "plan", "dontAsk"]
      },
      "allowDangerouslySkipPermissions": {
        "type": "boolean"
      },
      "includePartialMessages": {
        "type": "boolean"
      },
      "maxTurns": {
        "type": "number"
      },
      "maxThinkingTokens": {
        "type": "number"
      },
      "requestTimeoutMs": {
        "type": "number"
      },
      "capabilityProbe": {
        "type": "boolean"
      },
      "capabilityCacheTtlMs": {
        "type": "number"
      },
      "probeTimeoutMs": {
        "type": "number"
      },
      "executionProbeTimeoutMs": {
        "type": "number"
      },
      "verifyExecution": {
        "type": "boolean"
      },
      "additionalDirectories": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "allowedTools": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "disallowedTools": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "settingSources": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["user", "project", "local"]
        }
      },
      "pathToClaudeCodeExecutable": {
        "type": "string"
      },
      "claudeCodePath": {
        "type": "string"
      },
      "executable": {
        "type": "string",
        "enum": ["node", "bun", "deno"]
      },
      "executableArgs": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "extraArgs": {
        "type": "object",
        "additionalProperties": true
      },
      "sandbox": {
        "type": "object",
        "additionalProperties": true
      },
      "persistSession": {
        "type": "boolean"
      },
      "continue": {
        "type": "boolean"
      },
      "env": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      },
      "config": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "uiHints": {
    "apiKey": {
      "label": "Claude API Key",
      "help": "Optional explicit fallback. Prefer configuring a Claude-compatible provider/model in NextClaw.",
      "sensitive": true
    },
    "authToken": {
      "label": "Claude Auth Token",
      "help": "Optional explicit fallback for Anthropic-compatible gateways.",
      "sensitive": true
    },
    "apiBase": {
      "label": "Claude API Base",
      "help": "Optional explicit fallback. Anthropic-compatible provider routes should usually come from Providers."
    },
    "model": {
      "label": "Default Model"
    },
    "useProviderCredentials": {
      "label": "Force Current Provider Credentials",
      "advanced": true
    },
    "anthropicCompatibleProviderNames": {
      "label": "Anthropic-Compatible Providers",
      "advanced": true
    },
    "gatewayProviderNames": {
      "label": "Claude Gateway Providers",
      "advanced": true
    },
    "workingDirectory": {
      "label": "Working Directory",
      "advanced": true
    },
    "permissionMode": {
      "label": "Permission Mode",
      "advanced": true
    },
    "maxTurns": {
      "label": "Max Turns",
      "advanced": true
    },
    "requestTimeoutMs": {
      "label": "Request Timeout (ms)",
      "advanced": true
    },
    "capabilityProbe": {
      "label": "Capability Probe",
      "advanced": true
    },
    "verifyExecution": {
      "label": "Verify Execution",
      "advanced": true
    },
    "allowedTools": {
      "label": "Allowed Tools",
      "advanced": true
    },
    "disallowedTools": {
      "label": "Disallowed Tools",
      "advanced": true
    }
  }
}
