{
  "name": "@nextclaw/nextclaw-ncp-runtime-codex-sdk",
  "version": "0.1.39-beta.4",
  "private": false,
  "description": "Optional NCP runtime adapter backed by OpenAI Codex SDK.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --dts.sourcemap --clean --target es2022 --no-fixedExtension --unbundle",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "test": "vitest run src/utils/codex-model-provider.utils.test.ts src/utils/codex-sdk-ncp-event-mapper.utils.test.ts src/services/codex-live-output-stream.service.test.ts src/utils/codex-openai-sse-chunks.utils.test.ts",
    "tsc": "tsc -p tsconfig.json",
    "prepublishOnly": "node ../../../scripts/release/ensure-pnpm-publish.mjs"
  },
  "files": [
    "dist",
    "codex-sdk-loader.cjs",
    "README.md"
  ],
  "dependencies": {
    "@nextclaw/ncp": "workspace:*",
    "@openai/codex-sdk": "^0.130.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  }
}
