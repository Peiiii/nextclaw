{
  "name": "@nextclaw/nextclaw-ncp-runtime-claude-code-sdk",
  "version": "0.2.8",
  "private": false,
  "description": "Optional NCP runtime adapter backed by Anthropic Claude Agent SDK.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --dts.sourcemap --clean --target es2022 --no-fixedExtension --unbundle",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "test": "vitest run",
    "tsc": "tsc -p tsconfig.json",
    "prepublishOnly": "node ../../../scripts/release/ensure-pnpm-publish.mjs"
  },
  "files": [
    "dist",
    "claude-code-loader.cjs",
    "README.md"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nextclaw/ncp": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  }
}
