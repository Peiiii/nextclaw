{
  "name": "@nextclaw/channel-extension-qq",
  "version": "0.1.0",
  "private": false,
  "description": "NextClaw QQ channel extension process.",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "nextclaw.extension.json"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/main.ts --dts --clean --target es2022 --no-fixedExtension --unbundle",
    "prepack": "pnpm run build",
    "lint": "eslint src --max-warnings=0",
    "tsc": "tsc -p tsconfig.json",
    "prepublishOnly": "node ../../../scripts/release/ensure-pnpm-publish.mjs"
  },
  "dependencies": {
    "@nextclaw/channel-runtime": "workspace:*",
    "@nextclaw/extension-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "typescript": "^5.6.3"
  }
}
