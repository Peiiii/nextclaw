{
  "name": "@nextclaw/client-sdk",
  "version": "0.1.14-beta.5",
  "private": false,
  "description": "Shared client SDK for NextClaw session, agent, and realtime access.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Peiiii/nextclaw.git"
  },
  "homepage": "https://github.com/Peiiii/nextclaw/tree/master/packages/nextclaw-client-sdk",
  "bugs": {
    "url": "https://github.com/Peiiii/nextclaw/issues"
  },
  "keywords": [
    "nextclaw",
    "client-sdk",
    "session",
    "realtime"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts.sourcemap --clean --target es2022 --no-fixedExtension --unbundle",
    "prepack": "pnpm run build",
    "lint": "eslint src --max-warnings=0",
    "tsc": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "node ../../scripts/release/ensure-pnpm-publish.mjs"
  },
  "dependencies": {
    "@nextclaw/shared": "workspace:*",
    "@nextclaw/server": "workspace:*",
    "@nextclaw/ncp": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  }
}
