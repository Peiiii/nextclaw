{
  "name": "@nextclaw/service",
  "version": "0.3.12",
  "private": false,
  "description": "NextClaw long-running service host and runtime lifecycle.",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "development": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./*": {
      "development": "./src/*",
      "types": "./dist/*",
      "default": "./dist/*"
    }
  },
  "files": [
    "dist"
  ],
  "nextclaw": {
    "builtinExtensions": [
      "@nextclaw/channel-extension-dingtalk",
      "@nextclaw/channel-extension-discord",
      "@nextclaw/channel-extension-email",
      "@nextclaw/channel-extension-feishu",
      "@nextclaw/channel-extension-qq",
      "@nextclaw/channel-extension-slack",
      "@nextclaw/channel-extension-telegram",
      "@nextclaw/channel-extension-wecom",
      "@nextclaw/channel-extension-weixin",
      "@nextclaw/channel-extension-whatsapp"
    ]
  },
  "scripts": {
    "build": "tsdown \"src/**/*.ts\" \"!src/**/*.test.ts\" \"!src/**/tests/**\" --dts.sourcemap --clean --target es2022 --no-fixedExtension --unbundle",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "tsc": "tsc -p tsconfig.json",
    "test": "vitest",
    "prepublishOnly": "node ../../scripts/release/ensure-pnpm-publish.mjs"
  },
  "dependencies": {
    "@nextclaw/channel-extension-dingtalk": "workspace:*",
    "@nextclaw/channel-extension-discord": "workspace:*",
    "@nextclaw/channel-extension-email": "workspace:*",
    "@nextclaw/channel-extension-feishu": "workspace:*",
    "@nextclaw/channel-extension-qq": "workspace:*",
    "@nextclaw/channel-extension-slack": "workspace:*",
    "@nextclaw/channel-extension-telegram": "workspace:*",
    "@nextclaw/channel-extension-wecom": "workspace:*",
    "@nextclaw/channel-extension-weixin": "workspace:*",
    "@nextclaw/channel-extension-whatsapp": "workspace:*",
    "@nextclaw/client-sdk": "workspace:*",
    "@nextclaw/core": "workspace:*",
    "@nextclaw/kernel": "workspace:*",
    "@nextclaw/mcp": "workspace:*",
    "@nextclaw/ncp": "workspace:*",
    "@nextclaw/ncp-agent-runtime": "workspace:*",
    "@nextclaw/ncp-mcp": "workspace:*",
    "@nextclaw/ncp-toolkit": "workspace:*",
    "@nextclaw/nextclaw-hermes-acp-bridge": "workspace:*",
    "@nextclaw/nextclaw-ncp-runtime-http-client": "workspace:*",
    "@nextclaw/nextclaw-ncp-runtime-stdio-client": "workspace:*",
    "@nextclaw/remote": "workspace:*",
    "@nextclaw/runtime": "workspace:*",
    "@nextclaw/server": "workspace:*",
    "@nextclaw/shared": "workspace:*",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  }
}
