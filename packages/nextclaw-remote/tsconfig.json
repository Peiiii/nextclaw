{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@nextclaw/core": [
        "../nextclaw-core/src/index.ts"
      ],
      "@nextclaw/kernel": [
        "../nextclaw-kernel/src/index.ts"
      ],
      "@kernel/*": [
