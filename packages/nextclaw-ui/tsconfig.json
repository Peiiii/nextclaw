{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["vite/client", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@/components/chat/ChatWelcome": ["./src/features/chat/components/chat-welcome.tsx"],
      "@/components/chat/chat-conversation-panel": ["./src/features/chat/components/conversation/chat-conversation-panel.tsx"],
      "@/components/chat/useChatSessionTypeState": ["./src/features/chat/hooks/use-chat-session-type-state.ts"],
      "@/*": ["./src/*"],
      "@nextclaw/agent-chat": ["../nextclaw-agent-chat/src/index.ts"],
      "@nextclaw/agent-chat-ui": ["../nextclaw-agent-chat-ui/src/index.ts"],
      "@nextclaw/ncp": ["../ncp-packages/nextclaw-ncp/src/index.ts"],
      "@nextclaw/ncp-http-agent-client": ["../ncp-packages/nextclaw-ncp-http-agent-client/src/index.ts"],
      "@nextclaw/ncp-react": ["../ncp-packages/nextclaw-ncp-react/src/index.ts"]
    }
  },
  "include": ["src"]
}
