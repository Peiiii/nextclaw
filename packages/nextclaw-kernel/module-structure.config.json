{
  "contractKind": "protocol",
  "protocol": "app-l1",
  "rootPolicy": "contract-only",
  "enforcement": "error",
  "allowedRootDirectories": [
    "app",
    "configs",
    "contributions",
    "features",
    "managers",
    "repositories",
    "services",
    "stores",
    "tools",
    "types",
    "utils"
  ],
  "allowedRootFiles": [
    "index.ts"
  ],
  "importAliasPrefixes": ["@kernel/"]
}
