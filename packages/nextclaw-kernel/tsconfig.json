{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2022"],
    "baseUrl": ".",
    "paths": {
      "@core/*": ["../nextclaw-core/src/*"],
      "@kernel/*": ["./src/*"],
      "@nextclaw/core": ["../nextclaw-core/src/index.ts"],
      "@nextclaw/mcp": ["../nextclaw-mcp/src/index.ts"],
      "@nextclaw/ncp": ["../ncp-packages/nextclaw-ncp/src/index.ts"],
      "@nextclaw/ncp-agent-runtime": ["../ncp-packages/nextclaw-ncp-agent-runtime/src/index.ts"],
      "@nextclaw/ncp-http-agent-server": ["../ncp-packages/nextclaw-ncp-http-agent-server/src/index.ts"],
      "@nextclaw/ncp-mcp": ["../ncp-packages/nextclaw-ncp-mcp/src/index.ts"],
      "@nextclaw/ncp-toolkit": ["../ncp-packages/nextclaw-ncp-toolkit/src/index.ts"],
      "@nextclaw/nextclaw-hermes-acp-bridge": ["../nextclaw-hermes-acp-bridge/src/index.ts"],
      "@nextclaw/nextclaw-ncp-runtime-http-client": ["../nextclaw-ncp-runtime-http-client/src/index.ts"],
      "@nextclaw/nextclaw-ncp-runtime-stdio-client": ["../nextclaw-ncp-runtime-stdio-client/src/index.ts"],
      "@nextclaw/openclaw-compat": ["../nextclaw-openclaw-compat/src/index.ts"],
      "@nextclaw/runtime": ["../nextclaw-runtime/src/index.ts"],
      "@nextclaw/shared": ["../nextclaw-shared/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
