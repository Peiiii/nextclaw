{
  "name": "@nextclaw/ncp-agent-runtime-next",
  "version": "0.0.5",
  "private": false,
  "description": "Next-generation NCP agent runtime implementation for review before replacing @nextclaw/ncp-agent-runtime.",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts.sourcemap --clean --target es2022 --no-fixedExtension",
    "lint": "eslint .",
    "prepublishOnly": "node ../../../scripts/release/ensure-pnpm-publish.mjs",
    "tsc": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@nextclaw/ncp": "workspace:*",
    "@nextclaw/ncp-agent-runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "typescript": "^5.6.3"
  }
}
