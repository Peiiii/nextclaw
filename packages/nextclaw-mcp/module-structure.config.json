{
  "contractKind": "protocol",
  "protocol": "package-src-explicit",
  "rootPolicy": "contract-only",
  "enforcement": "error",
  "allowedRootDirectories": [
    "client",
    "config",
    "doctor",
    "install",
    "lifecycle",
    "manage",
    "registry",
    "view"
  ],
  "allowedRootFiles": [
    "index.ts",
    "types.ts"
  ]
}
