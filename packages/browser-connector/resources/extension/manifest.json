{
  "manifest_version": 3,
  "name": "Browser Connector",
  "version": "0.1.0",
  "description": "Connects Chrome tabs to the local browser-connector Native Host.",
  "key": "",
  "permissions": [
    "activeTab",
    "nativeMessaging",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.controller.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Browser Connector"
  }
}
