{
  "name": "@nextclaw/core",
  "version": "0.14.4",
  "private": false,
  "description": "Nextclaw runtime core (agent, channels, providers, config).",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./child-process-env": {
      "development": "./src/shared/lib/core-utils/utils/child-process-env.utils.ts",
      "types": "./src/shared/lib/core-utils/utils/child-process-env.utils.ts",
      "default": "./dist/shared/lib/core-utils/utils/child-process-env.utils.js"
    }
  },
  "files": [
    "dist",
    "src/shared/lib/core-utils/utils/child-process-env.utils.ts"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/features/llm-providers/providers/types.ts src/features/session-search/worker/session-search-worker-host.utils.ts src/shared/lib/core-utils/utils/child-process-env.utils.ts --dts.sourcemap --clean --target es2022 --no-fixedExtension && node scripts/copy-skills.mjs",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "tsc": "tsc -p tsconfig.json",
    "test": "vitest",
    "prepublishOnly": "node ../../scripts/release/ensure-pnpm-publish.mjs"
  },
  "dependencies": {
    "@nextclaw/feishu-core": "workspace:*",
    "@nextclaw/shared": "workspace:*",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.4.5",
    "openai": "^4.74.0",
    "pino": "^9.4.0",
    "socket.io-msgpack-parser": "^3.0.2",
    "undici": "^6.21.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  }
}
