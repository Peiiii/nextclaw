{
  "contractKind": "protocol",
  "protocol": "package-src-explicit",
  "rootPolicy": "contract-only",
  "enforcement": "error",
  "allowedRootDirectories": [
    "agent",
    "bus",
    "channels",
    "commands",
    "config",
    "cron",
    "extensions",
    "heartbeat",
    "logging",
    "providers",
    "runtime-context",
    "session",
    "typed-event-bus",
    "utils"
  ],
  "allowedRootFiles": [
    "index.ts"
  ]
}
