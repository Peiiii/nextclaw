{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": ".",
    "module": "Node16",
    "moduleResolution": "Node16",
    "verbatimModuleSyntax": false,
    "jsx": "react-jsx",
    "types": ["node", "electron"],
    "lib": ["DOM", "ES2022"]
  },
  "include": ["electron/**/*.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
