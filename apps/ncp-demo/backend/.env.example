# Auto mode: if OPENAI_API_KEY + base_url/OPENAI_BASE_URL are set, backend uses real OpenAI-compatible API.
# Otherwise it falls back to mock LLM.
NCP_DEMO_LLM_MODE=auto

# Support both keys; OPENAI_BASE_URL has higher priority when both are present.
base_url=https://code.pumpkinai.vip/v1
# OPENAI_BASE_URL=https://code.pumpkinai.vip/v1

OPENAI_MODEL=gpt-5.3-codex
OPENAI_API_KEY=YOUR_API_KEY_HERE
